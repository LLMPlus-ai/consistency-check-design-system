# Consistency Check — back-end configuration (copy to server/.env)
#
# All keys are OPTIONAL. With none set, the verification engine runs in
# deterministic mode (local corpus only) and the product still works fully.
# Set these to enable the live "NVIDIA AI Processing Layer" + "Perplexity API".

# NVIDIA Nemotron open models, served via OpenRouter (https://openrouter.ai).
# Used for citation extraction and mischaracterisation analysis.
# Get a key at https://openrouter.ai/keys  (format: sk-or-v1-...)
OPENROUTER_API_KEY=

# Perplexity `sonar` — live web retrieval for out-of-corpus citations.
# Get a key at https://www.perplexity.ai/settings/api  (format: pplx-...)
PERPLEXITY_API_KEY=

# ── Database ───────────────────────────────────────────────────────────────
# The runtime state is persisted to the first backend configured below.
# Configure ONE of these; otherwise it falls back to a local file (server/db.json).
#
# 1) Supabase (recommended for Vercel — HTTPS, no connection pooling to exhaust)
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_KEY=sb_publishable_...        # publishable/anon key, or service-role key
#
# 2) Direct Postgres / Supabase pooler connection string (auto-creates the table)
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# 3) Local file (default — used when neither of the above is set)
# CC_DB_FILE=

# Port the local server listens on (default 4000).
# PORT=4000
